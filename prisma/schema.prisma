generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Lead {
  id                   String   @id @default(cuid())
  company              String
  contactName          String?
  addressOrContactInfo String?
  emailOrPhone         String?
  lastContactAt        String?
  actions              String?
  heat                 Int
  resultComment        String?
  nextActions          String?
  notes                String   @default("")
  status               String   @default("Uusi")
  priority             String   @default("Seurantaan")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  company   String
  amount    Float
  createdAt DateTime @default(now())
}
